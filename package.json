    "@types/mdx": "^2.0.13",
    "fuse.js": "^7.3.0",
    "lenis": "^1.3.21",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
